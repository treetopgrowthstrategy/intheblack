---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="In The Black Coffee Co. | Wholesale Coffee Sales. Commission Only."
  description="We sell your specialty coffee wholesale. You cover samples. We handle everything else. You only pay when we close."
>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-brand-border bg-brand-black/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 200" class="h-8 w-auto" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="20" y="40" width="100" height="16" rx="3"/>
          <rect x="40" y="30" width="60" height="14" rx="3"/>
          <path d="M12 56 L28 190 L112 190 L128 56"/>
          <path d="M18 80 Q45 95 70 80 Q95 65 122 80"/>
          <path d="M20 110 Q47 125 72 110 Q97 95 124 110"/>
          <ellipse cx="70" cy="148" rx="22" ry="28"/>
          <path d="M70 122 Q62 148 70 175"/>
        </svg>
        <span class="font-display font-semibold text-lg tracking-wide">
          In The <span class="gold-text">Black</span>
        </span>
      </a>
      <a
        href="#contact"
        class="border border-brand-gold text-brand-gold font-body font-semibold text-sm px-5 py-2.5 hover:bg-brand-gold hover:text-brand-black transition-all"
      >
        Work With Us
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center pt-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #C9A84C 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="max-w-6xl mx-auto w-full py-24 relative">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Left: Copy -->
        <div>
          <div class="gold-line h-px w-24 mb-12"></div>
          <h1 class="font-display font-light text-6xl md:text-7xl leading-[1.0] tracking-tight mb-8 fade-up">
            We put your<br />
            roastery<br />
            <span class="gold-text font-semibold">in the black.</span>
          </h1>
          <p class="text-gray-400 text-xl font-body font-light max-w-xl mb-12 leading-relaxed fade-up-2">
            Commissioned wholesale sales for specialty coffee roasters. We find the accounts, send the samples, close the deals. You pay nothing until we do.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 fade-up-3">
            <a
              href="#contact"
              class="bg-brand-gold text-brand-black font-body font-bold text-base px-8 py-4 hover:bg-brand-gold-light transition-all text-center"
            >
              Let's Talk
            </a>
            <a
              href="#how-it-works"
              class="border border-brand-border text-white font-body text-base px-8 py-4 hover:border-brand-gold/50 transition-all text-center"
            >
              See How It Works
            </a>
          </div>
        </div>
        <!-- Right: Image -->
        <div class="relative fade-up-2">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black via-transparent to-transparent z-10 rounded-2xl"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-brand-black via-transparent to-transparent z-10 rounded-2xl"></div>
          <img
            src="/hero-barista.jpg"
            alt="Specialty coffee barista"
            class="w-full h-[600px] object-cover rounded-2xl opacity-90"
          />
          <!-- Gold accent overlay -->
          <div class="absolute bottom-6 left-6 z-20 border-l-2 border-brand-gold pl-4">
            <p class="text-white font-display text-lg font-light">Your coffee.</p>
            <p class="gold-text font-display text-lg font-semibold">New accounts.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE OFFER -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-brand-gold font-mono text-xs uppercase tracking-widest mb-6">The Offer</p>
          <h2 class="font-display font-light text-4xl md:text-5xl mb-8 leading-tight">
            No retainer.<br />No monthly fee.<br /><span class="gold-text">No risk.</span>
          </h2>
          <p class="text-gray-400 leading-relaxed mb-8">
            Most roasters don't have a wholesale sales problem. They have a bandwidth problem. You're running a roasting operation — you don't have time to cold call cafés, follow up on samples, and close accounts.
          </p>
          <p class="text-white font-body text-lg">
            That's exactly what we do. And we only get paid when you do.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { label: "You pay for", value: "Samples + shipping. That's it." },
            { label: "We handle", value: "Prospecting, outreach, follow-up, closing" },
            { label: "We even", value: "Print labels and package your samples" },
            { label: "You pay us", value: "Commission only — when we close" },
          ].map(item => (
            <div class="border border-brand-border p-6 flex justify-between items-start">
              <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mt-0.5">{item.label}</p>
              <p class="text-white font-body text-sm text-right max-w-[60%]">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="px-6 py-24 border-t border-brand-border bg-brand-card">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand-gold font-mono text-xs uppercase tracking-widest mb-12">How It Works</p>
      <div class="grid md:grid-cols-4 gap-8">
        {[
          { step: "01", title: "We Find the Accounts", body: "We research and identify cafés, restaurants, and wholesale buyers in your target markets. The right fit for your coffee." },
          { step: "02", title: "We Run Outreach", body: "Cold outreach via email and phone. We follow up until we get a yes or a no. No leads go cold." },
          { step: "03", title: "We Send Samples", body: "We print your labels, package your samples, and ship them. You just send us the beans." },
          { step: "04", title: "We Close", body: "Warm buyers converted to wholesale accounts. You fulfill the orders. We collect our commission." }
        ].map(item => (
          <div class="border-t border-brand-gold/30 pt-8">
            <p class="font-mono text-brand-gold/40 text-3xl font-bold mb-6">{item.step}</p>
            <h3 class="font-display font-semibold text-xl mb-3 text-white">{item.title}</h3>
            <p class="text-gray-500 font-body text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO WE WORK WITH -->
  <section class="px-6 py-24 border-t border-brand-border">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-brand-gold font-mono text-xs uppercase tracking-widest mb-6">Who We Work With</p>
        <h2 class="font-display font-light text-4xl md:text-5xl mb-8 leading-tight">
          Built for roasters<br />ready to grow<br /><span class="gold-text">wholesale.</span>
        </h2>
        <ul class="space-y-4">
          {[
            "Specialty roasters with a great product and real capacity",
            "Operations that want wholesale accounts without hiring sales staff",
            "Roasters tired of chasing leads that never close",
            "Anyone who's ever said 'we just need someone to sell for us'"
          ].map(item => (
            <li class="flex items-start gap-4 text-gray-400 font-body text-sm">
              <span class="text-brand-gold mt-0.5">—</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="border border-brand-border p-10">
        <p class="font-display font-light text-2xl text-gray-300 leading-relaxed mb-8 italic">
          "We don't work with everyone. We work with roasters who have a product worth selling and the capacity to fulfill what we close."
        </p>
        <div class="gold-line h-px w-16"></div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="px-6 py-24 border-t border-brand-border bg-brand-card">
    <div class="max-w-6xl mx-auto">
      <p class="text-brand-gold font-mono text-xs uppercase tracking-widest mb-4">Pricing</p>
      <h2 class="font-display font-light text-4xl mb-4 text-white">Simple. Transparent. No surprises.</h2>
      <p class="text-gray-500 font-body mb-12 max-w-xl">You cover samples. We close accounts. Our commission scales with the contract — the bigger the deal, the better for everyone.</p>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl">
        <div class="border border-brand-gold/30 p-8">
          <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-4">Year 1</p>
          <p class="font-display font-semibold text-6xl gold-text mb-2">10%</p>
          <p class="text-gray-400 text-sm leading-relaxed">Of the first year's wholesale contract value. Payable when the account closes.</p>
        </div>
        <div class="border border-brand-border p-8">
          <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-4">Renewals</p>
          <p class="font-display font-semibold text-6xl text-white mb-2">5%</p>
          <p class="text-gray-400 text-sm leading-relaxed">Annual renewal commission. We stay invested in keeping your accounts — not just closing them.</p>
        </div>
        <div class="border border-brand-border p-8 relative">
          <div class="absolute top-4 right-4 bg-brand-gold/10 border border-brand-gold/30 px-2 py-1">
            <p class="text-brand-gold font-mono text-xs">Best Value</p>
          </div>
          <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-4">Multi-Year</p>
          <p class="font-display font-semibold text-6xl text-white mb-2">8%</p>
          <p class="text-gray-400 text-sm leading-relaxed">Of total contract value for 2-3 year commitments. Bigger deal, better rate — locked in revenue for everyone.</p>
        </div>
      </div>

      <div class="mt-8 border border-brand-border p-6 max-w-4xl">
        <p class="text-gray-500 text-sm font-body">
          <span class="text-brand-gold font-semibold">Sample costs</span> — covered by you. We print labels, package, and ship on your behalf. No setup fees, no retainer, no monthly costs. Ever.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section id="contact" class="px-6 py-32 border-t border-brand-border relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #C9A84C 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="max-w-3xl mx-auto relative">
      <div class="text-center mb-16">
        <p class="text-brand-gold font-mono text-xs uppercase tracking-widest mb-6">Work With Us</p>
        <h2 class="font-display font-light text-5xl md:text-6xl mb-6 leading-tight">
          Let's see if we're <span class="gold-text font-semibold">a fit.</span>
        </h2>
        <p class="text-gray-400 text-lg max-w-xl mx-auto leading-relaxed">
          Tell us about your roastery. We'll be in touch within one business day.
        </p>
      </div>

      <!-- Form -->
      <div id="contact-form-wrapper">
        <form id="contact-form" action="/api/contact" method="POST" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="roastery" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Roastery Name *</label>
              <input type="text" id="roastery" name="roastery" required
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="Your roastery name" />
            </div>
            <div>
              <label for="name" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Your Name *</label>
              <input type="text" id="name" name="name" required
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="Full name" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Email Address *</label>
              <input type="email" id="email" name="email" required
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="you@roastery.com" />
            </div>
            <div>
              <label for="phone" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Phone Number</label>
              <input type="tel" id="phone" name="phone"
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="(optional)" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="markets" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Primary Markets *</label>
              <input type="text" id="markets" name="markets" required
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="e.g. Austin TX, Denver CO" />
            </div>
            <div>
              <label for="volume" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Monthly Roasting Volume *</label>
              <select id="volume" name="volume" required
                class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors appearance-none">
                <option value="" disabled selected class="text-gray-600">Select volume</option>
                <option value="Under 500 lbs">Under 500 lbs</option>
                <option value="500–2,000 lbs">500–2,000 lbs</option>
                <option value="2,000–5,000 lbs">2,000–5,000 lbs</option>
                <option value="5,000+ lbs">5,000+ lbs</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Tell us about your roastery</label>
            <textarea id="message" name="message" rows="4"
              class="w-full bg-brand-card border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600 resize-none"
              placeholder="What you're looking to grow, what makes your coffee special, anything we should know..."></textarea>
          </div>

          <div class="text-center pt-4">
            <button type="submit" id="submit-btn"
              class="bg-brand-gold text-brand-black font-body font-bold text-lg px-12 py-5 hover:bg-brand-gold-light transition-all cursor-pointer">
              Send It
            </button>
          </div>
        </form>
      </div>

      <!-- Success State (hidden by default) -->
      <div id="contact-success" class="hidden text-center py-16">
        <div class="gold-line h-px w-24 mx-auto mb-8"></div>
        <h3 class="font-display font-light text-3xl md:text-4xl mb-4 text-white">
          Got it. <span class="gold-text font-semibold">We'll be in touch.</span>
        </h3>
        <p class="text-gray-400 text-lg">Within one business day.</p>
      </div>

      <!-- Secondary CTA -->
      <div class="text-center mt-12 border-t border-brand-border pt-10">
        <p class="text-gray-500 font-body text-sm mb-3">Prefer a quick call?</p>
        <a href="https://calendar.app.google/sErhyQBke9cvrtv2A" target="_blank"
          class="text-brand-gold font-body font-semibold text-sm hover:text-brand-gold-light transition-colors">
          Book 20 minutes →
        </a>
      </div>
    </div>
  </section>

  <!-- Form Submission Script -->
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const wrapper = document.getElementById('contact-form-wrapper') as HTMLElement;
    const success = document.getElementById('contact-success') as HTMLElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => { data[key] = value.toString(); });

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          wrapper.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send It';
          alert('Something went wrong. Please try again or book a call instead.');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send It';
        alert('Something went wrong. Please try again or book a call instead.');
      }
    });
  </script>

  <!-- FOOTER -->
  <footer class="border-t border-brand-border px-6 py-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-gray-600 text-sm">
      <span class="flex items-center gap-2 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 200" class="h-6 w-auto" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="20" y="40" width="100" height="16" rx="3"/>
          <rect x="40" y="30" width="60" height="14" rx="3"/>
          <path d="M12 56 L28 190 L112 190 L128 56"/>
          <path d="M18 80 Q45 95 70 80 Q95 65 122 80"/>
          <path d="M20 110 Q47 125 72 110 Q97 95 124 110"/>
          <ellipse cx="70" cy="148" rx="22" ry="28"/>
          <path d="M70 122 Q62 148 70 175"/>
        </svg>
        <span class="font-display">In The <span class="gold-text">Black</span> Coffee Co.</span>
      </span>
      <p class="font-mono text-xs">intheblack.coffee</p>
      <p>© {new Date().getFullYear()} In The Black Coffee Co. All rights reserved.</p>
    </div>
  </footer>

</Layout>
