<ContentLayout
  title="Best Coffee for Restaurants: A Wholesale Buyer's Guide"
  description="How to evaluate and source wholesale specialty coffee for a restaurant program — what matters in a restaurant context, how to choose a roaster who understands it, and how to build a coffee program that earns its place on the menu."
  slug="best-coffee-for-restaurants"
  section="for-buyers"
  sectionLabel="For Buyers"
  publishDate="2025-06-01"
  updatedDate="2025-06-01"
