---
export const prerender = true;

const cities = [
  {
    slug: "chicago",
    city: "Chicago",
    tagline: "The Midwest's roasting engine",
    count: 8,
    highlight: "Intelligentsia, Dark Matter, Metropolis"
  },
  {
    slug: "nashville",
    city: "Nashville",
    tagline: "The South's fastest-rising coffee market",
    count: 7,
    highlight: "8th & Roast, Barista Parlor, Crema"
  },
  {
    slug: "austin",
    city: "Austin",
    tagline: "East Austin's roasting district",
    count: 7,
    highlight: "Cuvée, Merit, Flat Track"
  },
  {
    slug: "denver",
    city: "Denver",
    tagline: "Direct trade at altitude",
    count: 7,
    highlight: "Corvus, Huckleberry, Novo"
  },
  {
    slug: "portland",
    city: "Portland",
    tagline: "80+ roasters. One benchmark city.",
    count: 8,
    highlight: "Stumptown, Coava, Heart"
  }
];

const hubSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Top Specialty Coffee Roasters by City",
  "description": "In-depth guides to the best specialty coffee roasters in cities across the US — written for wholesale buyers, café operators, and serious coffee professionals.",
  "url": "https://intheblack.coffee/top-roasters",
  "publisher": {
    "@type": "Organization",
    "name": "In The Black Coffee Co.",
    "url": "https://intheblack.coffee"
  }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Top Specialty Coffee Roasters by City | In The Black Coffee Co.</title>
  <meta name="description" content="In-depth guides to the best specialty coffee roasters in Chicago, Nashville, Austin, Denver, Portland, and beyond. Written for wholesale buyers and serious coffee professionals." />
  <link rel="canonical" href="https://intheblack.coffee/top-roasters" />
  <script type="application/ld+json" set:html={JSON.stringify(hubSchema)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --espresso: #0f0b08;
      --espresso-mid: #1a1410;
      --espresso-light: #261e17;
      --gold: #C9A84C;
      --gold-pale: #e8d5a3;
      --cream: #f5f0e8;
      --text-body: #c4b9ab;
      --text-dim: #7a6e64;
      --border: rgba(201, 168, 76, 0.15);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--espresso);
      color: var(--text-body);
      font-family: 'Source Serif 4', Georgia, serif;
      -webkit-font-smoothing: antialiased;
    }
    .nav {
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--cream);
    }
    .nav-logo span { color: var(--gold); }
    .nav-cta {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border: 1px solid var(--gold);
      padding: 0.45rem 1rem;
    }

    .hero {
      max-width: 760px;
      margin: 0 auto;
      padding: 5rem 2rem 3.5rem;
      text-align: center;
    }
    .hero-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      display: block;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 300;
      line-height: 1.15;
      color: var(--cream);
      margin-bottom: 1.25rem;
    }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero p {
      font-size: 1.05rem;
      color: var(--text-body);
      line-height: 1.8;
      max-width: 540px;
      margin: 0 auto;
    }
    .gold-rule {
      width: 48px;
      height: 1px;
      background: var(--gold);
      margin: 2.5rem auto;
      opacity: 0.5;
    }

    .grid-wrap {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem 6rem;
    }
    .city-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .city-card {
      border: 1px solid var(--border);
      background: var(--espresso-mid);
      padding: 2rem;
      text-decoration: none;
      display: block;
      position: relative;
      transition: border-color 0.2s;
    }
    .city-card::after {
      content: '→';
      position: absolute;
      bottom: 1.5rem;
      right: 1.5rem;
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-dim);
      transition: color 0.2s, transform 0.2s;
    }
    .city-card:hover { border-color: var(--gold); }
    .city-card:hover::after { color: var(--gold); transform: translateX(3px); }
    .city-count {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.6rem;
    }
    .city-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.75rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 0.4rem;
      line-height: 1.2;
    }
    .city-tagline {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 1.25rem;
    }
    .city-highlight {
      font-size: 0.9rem;
      color: var(--text-body);
      line-height: 1.6;
    }

    .coming-soon {
      border: 1px dashed rgba(201, 168, 76, 0.2);
      padding: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .coming-soon-text {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    .about-strip {
      border-top: 1px solid var(--border);
      max-width: 760px;
      margin: 0 auto;
      padding: 4rem 2rem;
      text-align: center;
    }
    .about-strip h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.75rem;
      font-weight: 300;
      color: var(--cream);
      margin-bottom: 1rem;
    }
    .about-strip h2 em { color: var(--gold); font-style: italic; }
    .about-strip p {
      color: var(--text-body);
      font-size: 0.95rem;
      line-height: 1.8;
      max-width: 520px;
      margin: 0 auto 1.5rem;
    }
    .about-link {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(201, 168, 76, 0.3);
      padding-bottom: 2px;
    }
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem;
      text-align: center;
    }
    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--cream);
      margin-bottom: 0.75rem;
    }
    .footer-logo span { color: var(--gold); }
    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem;
      color: var(--text-dim);
    }
    @media (max-width: 600px) {
      .nav { padding: 1rem; }
      .hero { padding: 3rem 1.25rem 2.5rem; }
      .grid-wrap { padding: 0 1.25rem 4rem; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-logo">In The <span>Black</span> Coffee Co.</a>
    <a href="/contact" class="nav-cta">Work With Us</a>
  </nav>

  <header class="hero">
    <span class="hero-eyebrow">Specialty Coffee · City Guides</span>
    <h1>Top Roasters <em>by City</em></h1>
    <p>In-depth guides to the specialty coffee roasters defining each market — written for wholesale buyers, café operators, and anyone who wants to know who's actually worth talking to.</p>
    <div class="gold-rule"></div>
  </header>

  <main class="grid-wrap">
    <div class="city-grid">
      {cities.map(c => (
        <a href={`/top-roasters/${c.slug}`} class="city-card">
          <div class="city-count">{c.count} roasters</div>
          <div class="city-name">{c.city}</div>
          <div class="city-tagline">{c.tagline}</div>
          <div class="city-highlight">{c.highlight}</div>
        </a>
      ))}
      <div class="coming-soon">
        <span class="coming-soon-text">More cities coming</span>
      </div>
    </div>
  </main>

  <section class="about-strip">
    <h2>About <em>In The Black</em></h2>
    <p>In The Black Coffee Co. is a commission-only wholesale coffee sales agency. We represent exceptional specialty roasters and place their coffee in cafés, restaurants, and office accounts across the country. You only pay when we close.</p>
    <a href="/about" class="about-link">Learn about the model →</a>
  </section>

  <footer>
    <div class="footer-logo">In The <span>Black</span> Coffee Co.</div>
    <p class="footer-copy">© {new Date().getFullYear()} In The Black Coffee Co. · intheblack.coffee</p>
  </footer>
</body>
</html>
