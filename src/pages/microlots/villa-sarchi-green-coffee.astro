<ContentLayout
  title="Villa Sarchi Green Coffee: A Roaster's Guide"
  description="The Villa Sarchi variety explained: a dwarf Bourbon mutation with bright, sweet, clean character. How to roast it, blend uses, and where to source it."
  slug="microlots/villa-sarchi-green-coffee"
  section="microlots"
  sectionLabel="Microlot Guides"
