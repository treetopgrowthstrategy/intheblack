const faqItems = [
  {
    q: "What should a cold outreach email to a café say?",
    a: "Keep it under 100 words. One sentence introducing yourself and your roastery. One sentence on why you're reaching out to this specific café — not generic flattery, something specific you noticed. An offer to send samples. A single, easy ask. The goal is not to close the account in the first email; the goal is to get samples in the door."
  },
  {
    q: "How do you pitch a coffee roastery to a restaurant buyer?",
    a: "Restaurant buyers care about three things: will guests enjoy it, will it run consistently, and will the service be there when something goes wrong. Lead with those. Mention specific accounts similar to theirs that you serve. Offer a staff cupping session rather than just samples — restaurant teams make decisions as a group. Come with suggested batch brew parameters already calculated for their equipment."
  },
  {
    q: "What do you say when a café already has a roaster they like?",
    a: "Don't compete on dissatisfaction you haven't earned. Instead: acknowledge it ('Good — I'd expect you to have a roaster you trust at your stage'), differentiate without disparaging ('What I'd offer alongside or as an alternative is...'), and make the ask low-commitment ('Would you be open to a guest sample pack? No obligation to switch anything — just want you to know what we're doing.'). Make switching feel optional, not necessary."
  }
