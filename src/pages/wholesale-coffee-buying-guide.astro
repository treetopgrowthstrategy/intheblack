export const prerender = true;

const faqItems = [
  {
    q: "What's the minimum order for specialty wholesale coffee?",
    a: "Minimums vary by roaster, but most specialty wholesale programs set a floor of $75–$150 per order, or a weekly volume commitment of 10–20 lbs. High-volume roasters may set higher minimums; smaller craft roasters often have more flexibility. If your volume is below most minimums, look for roasters who offer tiered entry — some start smaller accounts at lower thresholds and scale requirements as the relationship grows."
  },
  {
    q: "How do I evaluate a specialty coffee roaster before committing to a wholesale partnership?",
    a: "Request samples before signing anything, and taste them the way your customers will drink them — not just off a cupping spoon. Evaluate: cup quality consistency across two or three separate lots, responsiveness when you contact them, clarity of their pricing and terms, and whether they can articulate their sourcing philosophy in specific terms. A roaster who can tell you the farm, the altitude, and the processing method for each offering is one who knows their supply chain."
  },
  {
    q: "What's the difference between specialty coffee and commercial coffee for wholesale?",
    a: "Specialty coffee is scored 80 points or above on the Specialty Coffee Association's 100-point scale, produced from arabica varieties, and traceable to specific growing regions or farms. Commercial coffee is typically commodity-grade robusta or low-scoring arabica, purchased on commodity markets without farm traceability. For wholesale buyers, the practical differences are cup quality, price, and story — specialty coffee costs more per pound but delivers meaningfully better cup quality and gives your team something to talk about."
  },
  {
    q: "How long does it take to switch wholesale coffee roasters?",
    a: "A roaster switch takes 2–4 weeks from first sample to first delivery if both parties move efficiently. The timeline: request samples (1 week), evaluate and decide (1–2 weeks), negotiate terms and sign agreement (3–5 days), receive first order (days to 1 week depending on roast and delivery schedule). If you're switching mid-season, request a two-week parallel supply period so your team can transition gradually."
  },
  {
    q: "Should a restaurant or hotel buy wholesale coffee from a local or national roaster?",
    a: "Both have merit. A local roaster offers faster delivery, in-person training visits, and a local story that resonates with guests in that community. A national roaster offers broader recognition, more standardized quality control, and often more sophisticated wholesale infrastructure. The right answer depends on what your guests value and what service level you need — local is often better for independent restaurants, national for multi-property hotel groups."
  }
];

