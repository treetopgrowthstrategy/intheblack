---
import ContentLayout from '../../layouts/ContentLayout.astro';
export const prerender = true;

const faqItems = [
  {
    q: "What is washed coffee?",
    a: "Washed coffee (also called wet-processed) is coffee where the fruit and mucilage of the cherry are removed from the seed before drying. The cherries are depulped, fermented in water tanks for 12 to 48 hours to break down the remaining mucilage, then washed with clean water and dried on raised beds or patios. The result is a coffee with a clean, clear cup that emphasizes the bean's intrinsic character and terroir rather than flavors derived from the fruit surrounding it."
  },
  {
    q: "What is natural coffee?",
    a: "Natural coffee (also called dry-processed) is coffee where the whole cherry is dried with the fruit still intact around the seed. Cherries are spread on raised beds or patios for 2 to 6 weeks, turned regularly to prevent mold, and dried until the fruit desiccates and can be hulled off. The extended contact with the fruit during drying imparts fruit sugars and fermentation flavors into the seed, producing a heavier-bodied, sweeter, more fruit-forward cup compared to washed."
  },
  {
    q: "Which is better: washed or natural coffee?",
    a: "Neither is objectively better; they are different and suit different taste preferences. Washed coffee is better if you want clarity, brightness, and a clean expression of terroir. Natural coffee is better if you want sweetness, body, and intense fruit or berry notes. For pour-over brewing with high-quality single-origins, washed is the traditional choice. For French press or for buyers who want a more complex, fruit-driven cup, naturals are compelling. Most specialty buyers who take coffee seriously end up enjoying both, in different contexts."
  },
  {
    q: "What is honey process coffee?",
    a: "Honey process is a middle ground between washed and natural: the outer cherry skin is removed (like washed) but some or all of the mucilage is left on the seed during drying (unlike washed). The amount of mucilage left determines the honey color: yellow honey (less mucilage, closer to washed), red honey (moderate mucilage), and black honey (maximum mucilage, closest to natural in flavor). Honey-processed coffees cup with more body and sweetness than washed but less fruit intensity than natural."
  },
  {
    q: "Does washed or natural coffee have more caffeine?",
    a: "The processing method does not significantly affect caffeine content. Caffeine is in the seed (the bean), and washing or drying the fruit around it does not add or remove caffeine from the seed. The caffeine difference between a washed and natural coffee from the same farm and variety is negligible. Caffeine content is more influenced by species (arabica vs robusta), variety, and roast level than by processing method."
  }
];

const relatedPages = [
  { href: '/learn/coffee-processing-methods', label: 'Coffee Guides', title: 'Coffee Processing Methods Explained' },
  { href: '/learn/best-natural-process-coffee', label: 'Buyers Guide', title: 'Best Natural Process Coffee to Buy Online' },
