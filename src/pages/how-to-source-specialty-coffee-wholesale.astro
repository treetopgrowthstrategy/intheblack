<ContentLayout
  title="How to Source Specialty Coffee Wholesale"
  description="A sourcing guide for café operators, restaurants, and buyers who want to understand how specialty wholesale coffee works — from origin to delivery, and how to evaluate what you're actually buying."
  slug="how-to-source-specialty-coffee-wholesale"
  section="for-buyers"
  sectionLabel="For Buyers"
  publishDate="2025-06-01"
  updatedDate="2025-06-01"
