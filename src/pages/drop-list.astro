---
export const prerender = true;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "The Drop List — First Access to Rare Coffee Microlots",
  "description": "Join The Drop List and get first access when limited El Quetzal microlots become available. Laurina, Geisha, Anaerobic Java, Pacamara — these lots sell out fast.",
  "url": "https://intheblack.coffee/drop-list",
  "publisher": {
    "@type": "Organization",
    "name": "In The Black Coffee Co.",
    "url": "https://intheblack.coffee"
  }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Drop List — First Access to Rare Coffee Microlots | In The Black Coffee Co.</title>
  <meta name="description" content="Join The Drop List. Get first access when limited El Quetzal microlots drop — Laurina, Geisha, Anaerobic Java, Pacamara. These lots sell out within days." />
  <link rel="canonical" href="https://intheblack.coffee/drop-list" />
  <meta property="og:title" content="The Drop List — First Access to Rare Coffee Microlots" />
  <meta property="og:description" content="Join The Drop List. Get first access when limited El Quetzal microlots drop — Laurina, Geisha, Anaerobic Java, Pacamara. These lots sell out within days." />
  <meta property="og:url" content="https://intheblack.coffee/drop-list" />
  <meta property="og:type" content="website" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --espresso: #0f0b08;
      --espresso-mid: #1a1410;
      --espresso-light: #261e17;
      --gold: #C9A84C;
      --gold-pale: #e8d5a3;
      --cream: #f5f0e8;
      --text-body: #c4b9ab;
      --text-dim: #7a6e64;
      --border: rgba(201, 168, 76, 0.15);
      --success: #4a7c59;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--espresso); color: var(--text-body); font-family: 'Source Serif 4', Georgia, serif; -webkit-font-smoothing: antialiased; }
    .nav { border-bottom: 1px solid var(--border); padding: 1.25rem 2rem; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 300; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; color: var(--cream); }
    .nav-logo span { color: var(--gold); }
    .nav-back { font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); text-decoration: none; }
    .nav-back:hover { color: var(--gold); }

    /* HERO */
    .hero { max-width: 680px; margin: 0 auto; padding: 6rem 2rem 4rem; text-align: center; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--gold); border: 1px solid rgba(201,168,76,0.3); padding: 0.35rem 0.85rem;
      margin-bottom: 2rem;
    }
    .hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.6rem, 6vw, 4.2rem); font-weight: 300; line-height: 1.1; color: var(--cream); margin-bottom: 1.5rem; }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero-sub { font-size: 1.05rem; color: var(--text-body); line-height: 1.8; max-width: 520px; margin: 0 auto 1rem; }
    .hero-note { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); }
    .gold-rule { width: 48px; height: 1px; background: var(--gold); margin: 2.5rem auto; opacity: 0.4; }

    /* LOTS PREVIEW */
    .lots-section { max-width: 760px; margin: 0 auto; padding: 0 2rem 4rem; }
    .lots-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1px; background: var(--border); margin-bottom: 4rem; }
    .lot-cell { background: var(--espresso-mid); padding: 1.5rem 1.25rem; }
    .lot-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 400; color: var(--cream); margin-bottom: 0.4rem; }
    .lot-detail { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); line-height: 1.6; }
    .lot-score { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--gold); font-weight: 300; margin-top: 0.75rem; }

    /* FORM */
    .form-wrap { max-width: 560px; margin: 0 auto; padding: 0 2rem; }
    .form-card { border: 1px solid var(--border); background: var(--espresso-light); padding: 2.5rem; position: relative; overflow: hidden; }
    .form-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
    .form-title { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; color: var(--cream); margin-bottom: 0.5rem; }
    .form-title em { color: var(--gold); font-style: italic; }
    .form-sub { font-size: 0.9rem; color: var(--text-body); line-height: 1.7; margin-bottom: 1.75rem; }
    .field { margin-bottom: 1rem; }
    .field label { display: block; font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.4rem; }
    .field input { width: 100%; background: var(--espresso); border: 1px solid rgba(201,168,76,0.2); color: var(--cream); font-family: 'Source Serif 4', serif; font-size: 0.95rem; padding: 0.75rem 1rem; outline: none; transition: border-color 0.2s; }
    .field input:focus { border-color: var(--gold); }
    .field input::placeholder { color: var(--text-dim); }
    .interests-label { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.6rem; display: block; }
    .interests-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1.25rem; }
    .interest-chip { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
    .interest-chip input[type="checkbox"] { appearance: none; width: 14px; height: 14px; border: 1px solid rgba(201,168,76,0.3); background: var(--espresso); cursor: pointer; flex-shrink: 0; position: relative; transition: background 0.15s, border-color 0.15s; }
    .interest-chip input[type="checkbox"]:checked { background: var(--gold); border-color: var(--gold); }
    .interest-chip input[type="checkbox"]:checked::after { content: '✓'; position: absolute; top: -1px; left: 1px; font-size: 10px; color: var(--espresso); font-weight: 700; }
    .interest-chip span { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-body); }
    .submit-btn { width: 100%; background: var(--gold); color: var(--espresso); font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; padding: 1rem; border: none; cursor: pointer; transition: background 0.2s, transform 0.15s; margin-top: 0.5rem; }
    .submit-btn:hover { background: var(--gold-pale); transform: translateY(-1px); }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .form-fine { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.08em; color: var(--text-dim); text-align: center; margin-top: 1rem; line-height: 1.6; }
    .success-msg { display: none; text-align: center; padding: 2rem; }
    .success-msg.visible { display: block; }
    .success-icon { font-size: 2rem; margin-bottom: 1rem; }
    .success-head { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--cream); margin-bottom: 0.5rem; }
    .success-head em { color: var(--gold); font-style: italic; }
    .success-body { font-size: 0.9rem; color: var(--text-body); line-height: 1.7; }

    /* WHY */
    .why-section { max-width: 680px; margin: 5rem auto 0; padding: 0 2rem 6rem; }
    .why-title { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; font-weight: 300; color: var(--cream); text-align: center; margin-bottom: 2.5rem; }
    .why-title em { color: var(--gold); font-style: italic; }
    .why-items { display: flex; flex-direction: column; gap: 1.5rem; }
    .why-item { display: flex; gap: 1.25rem; align-items: flex-start; }
    .why-num { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--gold); opacity: 0.5; line-height: 1; flex-shrink: 0; width: 2rem; }
    .why-text-head { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--cream); margin-bottom: 0.3rem; }
    .why-text-body { font-size: 0.9rem; color: var(--text-body); line-height: 1.7; }

    footer { border-top: 1px solid var(--border); padding: 2rem; text-align: center; }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; font-weight: 300; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cream); margin-bottom: 0.5rem; }
    .footer-logo span { color: var(--gold); }
    .footer-copy { font-family: 'DM Mono', monospace; font-size: 0.6rem; color: var(--text-dim); }

    @media (max-width: 600px) {
      .nav { padding: 1rem; }
      .hero { padding: 4rem 1.25rem 3rem; }
      .lots-section, .form-wrap, .why-section { padding-left: 1.25rem; padding-right: 1.25rem; }
      .form-card { padding: 2rem 1.25rem; }
      .interests-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">In The <span>Black</span> Coffee Co.</a>
  <a href="/microlots" class="nav-back">← Microlot Guides</a>
</nav>

<header class="hero">
  <div class="hero-badge">Limited Availability · Farm Direct</div>
  <h1>The <em>Drop List</em></h1>
  <p class="hero-sub">Some of the rarest specialty microlots in the world come from a single hillside in Matagalpa, Nicaragua. When a new lot drops — Laurina, Geisha, Anaerobic Java, Pacamara — the people on this list hear about it first.</p>
  <p class="hero-note">No newsletters. No noise. Just drops.</p>
  <div class="gold-rule"></div>
</header>

<!-- LOTS PREVIEW -->
<section class="lots-section">
  <div class="lots-grid">
    <div class="lot-cell">
      <div class="lot-name">Laurina</div>
      <div class="lot-detail">Washed · 85pt<br />Naturally low caffeine<br />Ultra-rare production</div>
      <div class="lot-score">85</div>
    </div>
    <div class="lot-cell">
      <div class="lot-name">Geisha</div>
      <div class="lot-detail">Washed · 87pt<br />Jasmine, peach, apple<br />2nd harvest at EQ</div>
      <div class="lot-score">87</div>
    </div>
    <div class="lot-cell">
      <div class="lot-name">Anaerobic Java</div>
      <div class="lot-detail">Natural · 87pt<br />Dried fruit, chocolate<br />Experimental process</div>
      <div class="lot-score">87</div>
    </div>
    <div class="lot-cell">
      <div class="lot-name">Pacamara</div>
      <div class="lot-detail">Washed · 87pt<br />Mango, citrus, savory<br />Limited lot</div>
      <div class="lot-score">87</div>
    </div>
    <div class="lot-cell">
      <div class="lot-name">Java Washed</div>
      <div class="lot-detail">Washed · 85pt<br />Floral, jasmine, citrus<br />20+ year flagship</div>
      <div class="lot-score">85</div>
    </div>
    <div class="lot-cell">
      <div class="lot-name">Future Lots</div>
      <div class="lot-detail">New varietals<br />Experimental lots<br />First access reserved</div>
      <div class="lot-score">TBD</div>
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-wrap">
  <div class="form-card">
    <div id="form-body">
      <h2 class="form-title">Join <em>The Drop List</em></h2>
      <p class="form-sub">Enter your email and tell us which lots you care about. When inventory opens, we'll reach out directly — before it goes public.</p>

      <form id="drop-form" novalidate>
        <div class="field">
          <label for="fname">First Name</label>
          <input type="text" id="fname" name="fname" placeholder="Your first name" autocomplete="given-name" />
        </div>
        <div class="field">
          <label for="email">Email Address <span style="color:var(--gold)">*</span></label>
          <input type="email" id="email" name="email" placeholder="you@roastery.com" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="roastery">Roastery or Business (optional)</label>
          <input type="text" id="roastery" name="roastery" placeholder="Your roastery name" />
        </div>

        <span class="interests-label">Lots I'm interested in</span>
        <div class="interests-grid">
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="Laurina" />
            <span>Laurina</span>
          </label>
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="Geisha" />
            <span>Geisha</span>
          </label>
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="Anaerobic Java" />
            <span>Anaerobic Java</span>
          </label>
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="Pacamara" />
            <span>Pacamara</span>
          </label>
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="Java Washed" />
            <span>Java Washed</span>
          </label>
          <label class="interest-chip">
            <input type="checkbox" name="interests" value="All Lots" checked />
            <span>All Lots</span>
          </label>
        </div>

        <button type="submit" class="submit-btn" id="submit-btn">Join The Drop List</button>
        <p class="form-fine">No spam. No newsletters. One email per drop, when inventory opens.<br />Unsubscribe any time.</p>
      </form>
    </div>

    <div class="success-msg" id="success-msg">
      <div class="success-icon">☕</div>
      <h3 class="success-head">You're on <em>The Drop List</em></h3>
      <p class="success-body">We'll reach out when new El Quetzal microlots become available. These lots sell out fast — sometimes within 48 hours of notification. Keep an eye on your inbox.</p>
    </div>
  </div>
</section>

<!-- WHY JOIN -->
<section class="why-section">
  <h2 class="why-title">Why <em>this list</em> matters</h2>
  <div class="why-items">
    <div class="why-item">
      <div class="why-num">1</div>
      <div>
        <div class="why-text-head">The lots are genuinely limited</div>
        <div class="why-text-body">Laurina 2025 production was under 1,000 lbs total. Geisha is in its second year at the farm. Pacamara is a single hillside parcel. These aren't marketing numbers — they're harvest constraints. Once a lot sells out, it's gone until next season.</div>
      </div>
    </div>
    <div class="why-item">
      <div class="why-num">2</div>
      <div>
        <div class="why-text-head">Farm-direct means faster allocation</div>
        <div class="why-text-body">El Quetzal is a fourth-generation estate that owns the farm, the mill, and the export. No importer middleman. When a lot clears processing, Drop List subscribers hear about available inventory directly — before it hits any marketplace.</div>
      </div>
    </div>
    <div class="why-item">
      <div class="why-num">3</div>
      <div>
        <div class="why-text-head">Scores that justify the search</div>
        <div class="why-text-body">Geisha, Anaerobic Java, and Pacamara all cupped at 87 points in 2026. Laurina at 85. These aren't curiosity lots — they're competition-grade coffees from a farm that's been producing specialty continuously since 1947.</div>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="footer-logo">In The <span>Black</span> Coffee Co.</div>
  <p class="footer-copy">© {new Date().getFullYear()} In The Black Coffee Co. · intheblack.coffee</p>
</footer>

<script>
  const form = document.getElementById('drop-form');
  const submitBtn = document.getElementById('submit-btn');
  const formBody = document.getElementById('form-body');
  const successMsg = document.getElementById('success-msg');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const email = document.getElementById('email').value.trim();
    if (!email || !email.includes('@')) {
      document.getElementById('email').focus();
      return;
    }

    const fname = document.getElementById('fname').value.trim();
    const roastery = document.getElementById('roastery').value.trim();
    const interests = Array.from(document.querySelectorAll('input[name="interests"]:checked')).map(cb => cb.value);

    // Store locally for now — wire to service later
    const submission = {
      email,
      fname,
      roastery,
      interests: interests.length ? interests : ['All Lots'],
      source: 'drop-list-page',
      timestamp: new Date().toISOString()
    };

    // Save to localStorage as fallback until backend is wired
    const existing = JSON.parse(localStorage.getItem('itb_drop_list') || '[]');
    existing.push(submission);
    localStorage.setItem('itb_drop_list', JSON.stringify(existing));

    // Show success
    submitBtn.disabled = true;
    formBody.style.display = 'none';
    successMsg.classList.add('visible');
  });
</script>

</body>
</html>
