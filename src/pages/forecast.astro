---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Your Wholesale Growth Forecast | In The Black Coffee Co."
  description="See what 12 months of commissioned wholesale sales could do for your roastery. Free personalized forecast."
>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-brand-border bg-brand-black/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 200" class="h-8 w-auto" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="20" y="40" width="100" height="16" rx="3"/>
          <rect x="40" y="30" width="60" height="14" rx="3"/>
          <path d="M12 56 L28 190 L112 190 L128 56"/>
          <path d="M18 80 Q45 95 70 80 Q95 65 122 80"/>
          <path d="M20 110 Q47 125 72 110 Q97 95 124 110"/>
          <ellipse cx="70" cy="148" rx="22" ry="28"/>
          <path d="M70 122 Q62 148 70 175"/>
        </svg>
        <span class="font-display font-semibold text-lg tracking-wide">
          In The <span class="gold-text">Black</span>
        </span>
      </a>
      <a
        href="/#contact"
        class="border border-brand-gold text-brand-gold font-body font-semibold text-sm px-5 py-2.5 hover:bg-brand-gold hover:text-brand-black transition-all"
      >
        Work With Us
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #C9A84C 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="max-w-4xl mx-auto text-center relative">
      <div class="gold-line h-px w-24 mx-auto mb-8"></div>
      <h1 class="font-display font-light text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6 fade-up">
        Your Wholesale<br />
        <span class="gold-text font-semibold">Growth Forecast</span>
      </h1>
      <p class="text-gray-400 text-xl font-body font-light max-w-2xl mx-auto leading-relaxed fade-up-2">
        Answer six questions about your roastery. We'll model what 12 months of commissioned wholesale sales could look like for your business.
      </p>
    </div>
  </section>

  <!-- FORECAST FORM -->
  <section class="px-6 pb-24">
    <div class="max-w-3xl mx-auto">

      <!-- Step 1: Business Inputs -->
      <div id="step-inputs" class="bg-brand-card border border-brand-border p-8 md:p-12">
        <h2 class="font-display font-light text-2xl md:text-3xl mb-2 text-white">
          Tell us about your <span class="gold-text font-semibold">roastery</span>
        </h2>
        <p class="text-gray-500 font-body text-sm mb-10">All fields required. Takes about 60 seconds.</p>

        <form id="forecast-form" class="space-y-8">
          <!-- Roasting Volume -->
          <div>
            <label for="monthly_volume" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Current monthly roasting volume (lbs)</label>
            <input type="number" id="monthly_volume" name="monthly_volume" required min="1"
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
              placeholder="e.g. 2000" />
          </div>

          <!-- Capacity -->
          <div>
            <label for="capacity" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Max monthly capacity with current equipment (lbs)</label>
            <input type="number" id="capacity" name="capacity" required min="1"
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
              placeholder="e.g. 5000" />
          </div>

          <!-- Current Contracts -->
          <div>
            <label for="current_contracts" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Wholesale contracts you're currently fulfilling</label>
            <input type="number" id="current_contracts" name="current_contracts" required min="0"
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
              placeholder="e.g. 8" />
          </div>

          <!-- Monthly Leads -->
          <div>
            <label for="monthly_leads" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">New wholesale leads you're generating per month</label>
            <input type="number" id="monthly_leads" name="monthly_leads" required min="0"
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
              placeholder="e.g. 3" />
          </div>

          <!-- Sales Conversations -->
          <div>
            <label for="monthly_conversations" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Sales conversations you generated last month</label>
            <input type="number" id="monthly_conversations" name="monthly_conversations" required min="0"
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
              placeholder="e.g. 1" />
          </div>

          <!-- Growth Target -->
          <div>
            <label for="growth_target" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">How much do you want to grow?</label>
            <select id="growth_target" name="growth_target" required
              class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors appearance-none">
              <option value="" disabled selected class="text-gray-600">Select a target</option>
              <option value="conservative">Steady — fill existing capacity</option>
              <option value="moderate">Moderate — grow 25-50% in 12 months</option>
              <option value="aggressive">Aggressive — double output in 12 months</option>
            </select>
          </div>

          <div class="gold-line h-px w-full my-8"></div>

          <!-- Gate: Contact Info -->
          <h3 class="font-display font-light text-xl text-white">Where should we send your <span class="gold-text font-semibold">forecast?</span></h3>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="business_name" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Business Name</label>
              <input type="text" id="business_name" name="business_name" required
                class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="Your roastery" />
            </div>
            <div>
              <label for="contact_name" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Your Name</label>
              <input type="text" id="contact_name" name="contact_name" required
                class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="Full name" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="you@roastery.com" />
            </div>
            <div>
              <label for="phone" class="block text-gray-400 font-mono text-xs uppercase tracking-widest mb-2">Phone</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full bg-brand-black border border-brand-border text-white font-body px-4 py-3 focus:border-brand-gold focus:outline-none transition-colors placeholder-gray-600"
                placeholder="(555) 555-5555" />
            </div>
          </div>

          <div class="text-center pt-4">
            <button type="submit" id="forecast-btn"
              class="bg-brand-gold text-brand-black font-body font-bold text-lg px-12 py-5 hover:bg-brand-gold-light transition-all cursor-pointer">
              Build My Forecast
            </button>
            <p class="text-gray-600 font-mono text-xs mt-4">Free. No obligation. Takes 10 seconds.</p>
          </div>
        </form>
      </div>

      <!-- Step 2: Forecast Results (hidden) -->
      <div id="forecast-results" class="hidden">

        <!-- Header -->
        <div class="text-center mb-12">
          <div class="gold-line h-px w-24 mx-auto mb-8"></div>
          <h2 class="font-display font-light text-3xl md:text-4xl mb-2 text-white">
            <span id="result-business-name" class="gold-text font-semibold"></span>
          </h2>
          <p class="text-gray-400 font-body text-lg">12-Month Wholesale Growth Forecast</p>
        </div>

        <!-- Current State Snapshot -->
        <div class="bg-brand-card border border-brand-border p-8 mb-8">
          <h3 class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-6">Where You Are Today</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div>
              <p class="font-display text-3xl font-semibold text-white" id="stat-current-volume">—</p>
              <p class="text-gray-500 font-mono text-xs mt-1">lbs / month</p>
            </div>
            <div>
              <p class="font-display text-3xl font-semibold text-white" id="stat-current-contracts">—</p>
              <p class="text-gray-500 font-mono text-xs mt-1">wholesale accounts</p>
            </div>
            <div>
              <p class="font-display text-3xl font-semibold text-white" id="stat-current-leads">—</p>
              <p class="text-gray-500 font-mono text-xs mt-1">leads / month</p>
            </div>
            <div>
              <p class="font-display text-3xl font-semibold text-white" id="stat-capacity-used">—</p>
              <p class="text-gray-500 font-mono text-xs mt-1">capacity used</p>
            </div>
          </div>
        </div>

        <!-- 12-Month Projection Table -->
        <div class="bg-brand-card border border-brand-border p-8 mb-8 overflow-x-auto">
          <h3 class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-6">Month-by-Month Projection</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-brand-border text-gray-500 font-mono text-xs uppercase tracking-widest">
                <th class="text-left py-3 pr-4">Month</th>
                <th class="text-right py-3 px-4">Volume (lbs)</th>
                <th class="text-right py-3 px-4">Accounts</th>
                <th class="text-right py-3 px-4">New Leads</th>
                <th class="text-right py-3 px-4">Revenue</th>
              </tr>
            </thead>
            <tbody id="projection-table" class="font-body">
            </tbody>
          </table>
        </div>

        <!-- Summary Cards -->
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="bg-brand-card border border-brand-border p-8 text-center">
            <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-3">Projected Month-12 Volume</p>
            <p class="font-display text-4xl font-semibold gold-text" id="summary-volume">—</p>
            <p class="text-gray-500 font-mono text-xs mt-2">lbs / month</p>
          </div>
          <div class="bg-brand-card border border-brand-border p-8 text-center">
            <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-3">Projected 12-Month Revenue</p>
            <p class="font-display text-4xl font-semibold gold-text" id="summary-revenue">—</p>
            <p class="text-gray-500 font-mono text-xs mt-2">wholesale revenue</p>
          </div>
          <div class="bg-brand-card border border-brand-border p-8 text-center">
            <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-3">New Accounts Added</p>
            <p class="font-display text-4xl font-semibold gold-text" id="summary-accounts">—</p>
            <p class="text-gray-500 font-mono text-xs mt-2">in 12 months</p>
          </div>
        </div>

        <!-- Bar Chart -->
        <div class="bg-brand-card border border-brand-border p-8 mb-8">
          <h3 class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-6">Revenue Growth Trajectory</h3>
          <div id="chart-container" class="flex items-end gap-2 h-48">
          </div>
          <div class="flex justify-between mt-3 text-gray-600 font-mono text-xs">
            <span>Month 1</span>
            <span>Month 12</span>
          </div>
        </div>

        <!-- Assumptions -->
        <div class="bg-brand-card border border-brand-border p-8 mb-12">
          <h3 class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-4">Model Assumptions</h3>
          <div class="text-gray-500 font-body text-sm space-y-2">
            <p>2.5% month-over-month output growth based on incremental account acquisition.</p>
            <p>Average wholesale price of $9.50/lb. Average new account orders 150 lbs/month with 60-day ramp to full volume.</p>
            <p>Lead-to-close conversion rate of 18% with a 45-day average sales cycle.</p>
            <p>Projections assume consistent outbound sales effort and sample fulfillment.</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center border-t border-brand-border pt-12">
          <h3 class="font-display font-light text-2xl md:text-3xl mb-4 text-white">
            Ready to make this <span class="gold-text font-semibold">real?</span>
          </h3>
          <p class="text-gray-400 font-body mb-8 max-w-lg mx-auto">
            We'll build a custom sales plan for your roastery. You only pay when we close.
          </p>
          <a href="https://calendar.app.google/sErhyQBke9cvrtv2A" target="_blank"
            class="inline-block bg-brand-gold text-brand-black font-body font-bold text-lg px-12 py-5 hover:bg-brand-gold-light transition-all">
            Book a Strategy Call
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-brand-border px-6 py-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-gray-600 text-sm">
      <span class="flex items-center gap-2 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 200" class="h-6 w-auto" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="20" y="40" width="100" height="16" rx="3"/>
          <rect x="40" y="30" width="60" height="14" rx="3"/>
          <path d="M12 56 L28 190 L112 190 L128 56"/>
          <path d="M18 80 Q45 95 70 80 Q95 65 122 80"/>
          <path d="M20 110 Q47 125 72 110 Q97 95 124 110"/>
          <ellipse cx="70" cy="148" rx="22" ry="28"/>
          <path d="M70 122 Q62 148 70 175"/>
        </svg>
        <span class="font-display">In The <span class="gold-text">Black</span> Coffee Co.</span>
      </span>
      <p class="font-mono text-xs">intheblack.coffee</p>
      <p>&copy; {new Date().getFullYear()} In The Black Coffee Co. All rights reserved.</p>
    </div>
  </footer>

  <!-- FORECAST ENGINE -->
  <script>
    const form = document.getElementById('forecast-form') as HTMLFormElement;
    const stepInputs = document.getElementById('step-inputs') as HTMLElement;
    const results = document.getElementById('forecast-results') as HTMLElement;
    const btn = document.getElementById('forecast-btn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Building forecast...';

      const fd = new FormData(form);
      const d: Record<string, string> = {};
      fd.forEach((v, k) => { d[k] = v.toString(); });

      // Parse inputs
      const monthlyVolume = parseFloat(d.monthly_volume) || 0;
      const capacity = parseFloat(d.capacity) || 0;
      const currentContracts = parseInt(d.current_contracts) || 0;
      const monthlyLeads = parseInt(d.monthly_leads) || 0;
      const monthlyConversations = parseInt(d.monthly_conversations) || 0;
      const growthTarget = d.growth_target;
      const businessName = d.business_name;

      // Growth multiplier based on target
      const growthMultiplier = growthTarget === 'aggressive' ? 1.5 : growthTarget === 'moderate' ? 1.0 : 0.7;

      // Model constants
      const PRICE_PER_LB = 9.50;
      const MOM_GROWTH = 0.025; // 2.5% base month-over-month
      const AVG_NEW_ACCOUNT_LBS = 150;
      const CONVERSION_RATE = 0.18;
      const RAMP_FACTOR = 0.6; // new accounts start at 60% volume, ramp up

      // In The Black adds leads on top of what roaster generates
      const itbLeadsPerMonth = Math.max(8, Math.round(monthlyLeads * 2.5 * growthMultiplier));
      const baseConversions = Math.round(itbLeadsPerMonth * CONVERSION_RATE);

      // Build 12-month projection
      const months: Array<{month: number; volume: number; accounts: number; leads: number; revenue: number}> = [];
      let runningVolume = monthlyVolume;
      let runningAccounts = currentContracts;
      let totalRevenue = 0;
      let totalNewAccounts = 0;

      for (let m = 1; m <= 12; m++) {
        // New accounts this month (with some variance)
        const variance = m <= 2 ? 0.5 : 1; // slower ramp in months 1-2
        const newAccountsThisMonth = Math.round(baseConversions * variance * (1 + (m - 1) * 0.03));

        // Volume grows from base growth + new account contribution
        const baseGrowth = runningVolume * MOM_GROWTH;
        const newAccountVolume = newAccountsThisMonth * AVG_NEW_ACCOUNT_LBS * (m <= 2 ? RAMP_FACTOR : 0.85);

        runningVolume = Math.min(runningVolume + baseGrowth + newAccountVolume, capacity * 1.15);
        runningAccounts += newAccountsThisMonth;
        totalNewAccounts += newAccountsThisMonth;

        const monthRevenue = runningVolume * PRICE_PER_LB;
        totalRevenue += monthRevenue;

        months.push({
          month: m,
          volume: Math.round(runningVolume),
          accounts: runningAccounts,
          leads: itbLeadsPerMonth + Math.round(m * 0.5),
          revenue: monthRevenue,
        });
      }

      // Populate current state
      (document.getElementById('stat-current-volume') as HTMLElement).textContent = monthlyVolume.toLocaleString();
      (document.getElementById('stat-current-contracts') as HTMLElement).textContent = currentContracts.toString();
      (document.getElementById('stat-current-leads') as HTMLElement).textContent = monthlyLeads.toString();
      (document.getElementById('stat-capacity-used') as HTMLElement).textContent = capacity > 0 ? Math.round((monthlyVolume / capacity) * 100) + '%' : '—';
      (document.getElementById('result-business-name') as HTMLElement).textContent = businessName;

      // Populate table
      const tbody = document.getElementById('projection-table') as HTMLElement;
      tbody.innerHTML = '';
      const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      const now = new Date();

      months.forEach((row, i) => {
        const monthDate = new Date(now.getFullYear(), now.getMonth() + i + 1);
        const label = monthNames[monthDate.getMonth()] + ' ' + monthDate.getFullYear();
        const isLast = i === 11;
        const tr = document.createElement('tr');
        tr.className = `border-b border-brand-border/50 ${isLast ? 'text-white font-semibold' : 'text-gray-400'}`;
        tr.innerHTML = `
          <td class="py-3 pr-4 font-mono text-xs">${label}</td>
          <td class="text-right py-3 px-4">${row.volume.toLocaleString()}</td>
          <td class="text-right py-3 px-4">${row.accounts}</td>
          <td class="text-right py-3 px-4">${row.leads}</td>
          <td class="text-right py-3 px-4 ${isLast ? 'gold-text' : ''}">$${Math.round(row.revenue).toLocaleString()}</td>
        `;
        tbody.appendChild(tr);
      });

      // Populate summary
      const lastMonth = months[11];
      (document.getElementById('summary-volume') as HTMLElement).textContent = lastMonth.volume.toLocaleString();
      (document.getElementById('summary-revenue') as HTMLElement).textContent = '$' + Math.round(totalRevenue).toLocaleString();
      (document.getElementById('summary-accounts') as HTMLElement).textContent = '+' + totalNewAccounts;

      // Build bar chart
      const chartContainer = document.getElementById('chart-container') as HTMLElement;
      chartContainer.innerHTML = '';
      const maxRevenue = Math.max(...months.map(m => m.revenue));
      months.forEach((row, i) => {
        const bar = document.createElement('div');
        const heightPct = (row.revenue / maxRevenue) * 100;
        bar.className = 'flex-1 rounded-t transition-all';
        bar.style.height = `${heightPct}%`;
        bar.style.background = i === 11
          ? 'linear-gradient(135deg, #C9A84C, #E8C96D)'
          : 'linear-gradient(180deg, #C9A84C44, #C9A84C22)';
        bar.title = `Month ${i + 1}: $${Math.round(row.revenue).toLocaleString()}`;
        chartContainer.appendChild(bar);
      });

      // Send lead to API
      try {
        await fetch('/api/forecast', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...d,
            projected_month12_volume: lastMonth.volume,
            projected_12month_revenue: Math.round(totalRevenue),
            projected_new_accounts: totalNewAccounts,
          }),
        });
      } catch {
        // Lead capture failed silently — don't block the forecast
      }

      // Show results
      stepInputs.classList.add('hidden');
      results.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>

</Layout>
