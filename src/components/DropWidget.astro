---
export interface Props {
  lotName: string;
}
const { lotName } = Astro.props;
const dropHref = `/drop-list?lot=${encodeURIComponent(lotName)}`;
---
<aside class="drop-widget">
  <div class="drop-widget-eyebrow">The Drop List</div>
  <h3 class="drop-widget-title">Get first access to the next {lotName} drop</h3>
  <p class="drop-widget-body">
    {lotName} lots from El Quetzal are small, and they sell out fast. Join The Drop List and we will email you the moment the next harvest is ready for sample or full lot, before it goes public. No spam, no monthly newsletter. Just a heads up when the coffee you want is available.
  </p>
  <a href={dropHref} class="drop-widget-btn">Join The Drop List</a>
</aside>
<style>
  .drop-widget {
    border: 1px solid var(--border);
    border-left: 2px solid var(--gold);
    background: var(--espresso-mid);
    padding: 2rem 2rem 2.25rem;
    margin: 2.75rem 0;
    position: relative;
    overflow: hidden;
  }
  .drop-widget::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, rgba(201, 168, 76, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }
  .drop-widget-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.85rem;
  }
  .drop-widget-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--cream);
    line-height: 1.25;
    margin-bottom: 0.85rem;
  }
  .drop-widget-body {
    color: var(--text-body);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 56ch;
  }
  .drop-widget-btn {
    display: inline-block;
    background: var(--gold);
    color: var(--espresso);
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 0.8rem 2rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .drop-widget-btn:hover {
    background: var(--gold-pale);
    transform: translateY(-1px);
  }
  @media (max-width: 600px) {
    .drop-widget { padding: 1.75rem 1.5rem; }
  }
</style>
